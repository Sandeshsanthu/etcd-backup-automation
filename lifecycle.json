{
  "rule": [
    {
      "action": { "type": "SetStorageClass", "storageClass": "COLDLINE" },
      "condition": { "age": 30, "matchesPrefix": ["etcd-snapshots/"] }
    },
    {
      "action": { "type": "Delete" },
      "condition": { "age": 365, "matchesPrefix": ["etcd-snapshots/"] }
    }
  ]
}
